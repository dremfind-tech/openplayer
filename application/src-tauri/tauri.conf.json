{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Beat",
  "version": "0.1.0",
  "identifier": "com.indcr.open-beat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Open Beat",
        "width": 1080,
        "height": 720,
        "decorations": false
      },
      {
        "label": "tray_popover",
        "title": "Open Beat Mini Player",
        "width": 360,
        "height": 180,
        "decorations": false,
        "visible": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost http://asset.localhost; media-src 'self' asset: https://asset.localhost http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
